        "ARMGCC_DIR": "${sourceDir}/../.mcuxpressotools/arm-gnu-toolchain-14.2.rel1-darwin-arm64-arm-none-eabi",
        "SdkRootDirPath": "${sourceDir}/../mcimx93_evk",
        "BOARD": "mcimx93evk",
        "MCUX_VENV_PATH": "${sourceDir}/../.mcuxpressotools/.venv/bin",
        "PATH": "$env{MCUX_VENV_PATH}${pathListSep}$penv{PATH}",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "cacheVariables": {}
    },
    {
      "name": "debug-env",
      "displayName": "debug-env",
      "hidden": true,
      "inherits": ["debug-env-windows", "debug-env-linux", "debug-env-macos"]
    },
    {
      "name": "release-env-windows",
