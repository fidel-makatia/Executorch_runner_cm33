        "SdkRootDirPath": "${sourceDir}/../mcimx93_evk",
        "BOARD": "mcimx93evk",
        "MCUX_VENV_PATH": "${sourceDir}/../.mcuxpressotools/.venv/bin",
        "PATH": "$env{MCUX_VENV_PATH}${pathListSep}$penv{PATH}",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "cacheVariables": {}
    },
    {
      "name": "debug-env-macos",
      "displayName": "debug-env-macos",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
