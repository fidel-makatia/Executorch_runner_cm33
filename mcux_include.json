{
  "version": 7,
  "cmakeMinimumRequired": {
    "major": 3
  },
  "configurePresets": [
    {
      "name": "debug-env-windows",
      "displayName": "debug-env-windows",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "environment": {
        "ARMGCC_DIR": "${sourceDir}/../.mcuxpressotools/arm-gnu-toolchain-14.2.rel1-mingw-w64-x86_64-arm-none-eabi",
        "SdkRootDirPath": "${sourceDir}/../mcimx93_evk",
        "BOARD": "mcimx93evk",
        "MCUX_VENV_PATH": "${sourceDir}/../.mcuxpressotools/.venv/Scripts",
        "PATH": "$env{MCUX_VENV_PATH}${pathListSep}$penv{PATH}",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "cacheVariables": {}
    },
    {
      "name": "debug-env-linux",
      "displayName": "debug-env-linux",
      "hidden": true,
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
